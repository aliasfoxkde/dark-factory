#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# Dark Factory Complexity Gate Pre-push Hook
#
# Blocks pushes if:
#   - Any function exceeds 50 lines
#   - Any file exceeds 500 lines
#   - Cyclomatic complexity > 10 (for/if chains)
#
# Usage: Add to .githooks/pre-push
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
cd "$REPO_ROOT"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
ERROR() { echo -e "${RED}[complexity-gate]${NC} $*"; }
WARN() { echo -e "${YELLOW}[complexity-gate]${NC} $*"; }
INFO() { echo -e "${GREEN}[complexity-gate]${NC} $*"; }

show_help() {
    cat << 'EOF'
Dark Factory Complexity Gate Pre-push Hook

Blocks push if:
  - Any function exceeds 50 lines (Go/Python)
  - Any file exceeds 500 lines
  - Cyclomatic complexity > 10 (for/if chains)

Exit codes:
  0 - All checks passed or skipped
  1 - Violation found

Usage: This hook runs automatically before push.
EOF
}

for arg in "$@"; do
    case "$arg" in
        -h|--help) show_help; exit 0 ;;
    esac
done

BLOCKED=0
VIOLATIONS=()

# Get list of files being pushed (compare against origin/{branch} or main)
REMOTE_REF="${1:-}"
LOCAL_REF="${2:-}"
LOCAL_COMMIT="${3:-}"

if [ -z "$LOCAL_REF" ] || [ -z "$LOCAL_COMMIT" ]; then
    INFO "No remote configured or nothing to push — skipping complexity gate"
    exit 0
fi

# Get list of changed/added files from the commits being pushed
if command -v git &>/dev/null && git rev-parse --git-dir &>/dev/null; then
    CHANGED_FILES=$(git diff --name-only "$LOCAL_REF".."$LOCAL_COMMIT" 2>/dev/null || echo "")
else
    INFO "Not in a git repo or git not available — skipping"
    exit 0
fi

if [ -z "$CHANGED_FILES" ]; then
    INFO "No files changed in this push — skipping complexity gate"
    exit 0
fi

# ─── 1. File length check (500 lines) ──────────────────────────────────────────
check_file_length() {
    local file="$1"
    local max_lines=500

    if [ ! -f "$file" ]; then
        return 0
    fi

    # Skip binary and generated files
    case "$file" in
        *.min.js|*.min.css|*.pb.go|*.pb.gw.go) return 0 ;;
    esac

    local line_count
    line_count=$(wc -l < "$file" 2>/dev/null || echo 0)

    if [ "$line_count" -gt "$max_lines" ]; then
        ERROR "FILE_TOO_LONG: $file has $line_count lines (max: $max_lines)"
        VIOLATIONS+=("FILE_TOO_LONG: $file:$line_count")
        BLOCKED=1
    fi
}

# ─── 2. Function length check (50 lines) ──────────────────────────────────────
check_function_length() {
    local file="$1"
    local max_func_lines=50

    if [ ! -f "$file" ]; then
        return 0
    fi

    # Only check source files
    case "$file" in
        *.go|*.py) ;;
        *) return 0 ;;
    esac

    if [ "$file" = "*.go" ]; then
        # Go: parse AST to find functions
        if command -v gofmt &>/dev/null; then
            local in_func=0
            local func_name=""
            local func_start=0
            local brace_count=0
            local line_num=0

            while IFS= read -r line; do
                line_num=$((line_num + 1))

                # Function detection
                if grep -qE '^func\s+('"$file"' )?[A-Z][a-zA-Z0-9]*\(' "$file" 2>/dev/null; then
                    if [ "$in_func" -eq 1 ]; then
                        # Previous function never closed (syntax error)
                        func_start=$line_num
                    else
                        func_start=$line_num
                        func_name=$(grep -nE '^func\s+('"$file"' )?[A-Z][a-zA-Z0-9]*\(' "$file" 2>/dev/null | tail -1 | sed 's/.*^func.*(\([^)]*\).*/\1/')
                        in_func=1
                        brace_count=0
                    fi
                fi

                # Count braces
                if [ "$in_func" -eq 1 ]; then
                    brace_count=$((brace_count + $(echo "$line" | tr -cd '{' | wc -c)))
                    brace_count=$((brace_count - $(echo "$line" | tr -cd '}' | wc -c)))

                    if [ "$brace_count" -le 0 ] && [ "$in_func" -eq 1 ]; then
                        local func_length=$((line_num - func_start))
                        if [ "$func_length" -gt "$max_func_lines" ]; then
                            ERROR "FUNCTION_TOO_LONG: $file:$func_start function '$func_name' has $func_length lines (max: $max_func_lines)"
                            VIOLATIONS+=("FUNCTION_TOO_LONG: $file:${func_start}:${func_length}")
                            BLOCKED=1
                        fi
                        in_func=0
                        func_name=""
                    fi
                fi
            done < "$file"
        fi
    elif [ "$file" = "*.py" ]; then
        # Python: use awk to track def blocks
        awk '
        BEGIN { in_def=0; def_name=""; def_start=0; brace_count=0 }
        /^def [a-zA-Z_][a-zA-Z0-9_]*\(/ {
            if (in_def && def_start > 0) {
                len = NR - def_start
                if (len > 50) {
                    print "FUNCTION_TOO_LONG: FILENAME:" def_start ":" len > "/dev/stderr"
                }
            }
            in_def = 1
            def_start = NR
            def_name = $0
            sub(/:.*/, "", def_name)
            sub("def ", "", def_name)
        }
        in_def && /^[ \t]*[^# \t]/ && !/^def / && !/^[ \t]*#/ {
            # Track indentation end
            if ($0 ~ /^[^ \t]/) {
                if (in_def) {
                    len = NR - def_start
                    if (len > 50) {
                        print "FUNCTION_TOO_LONG: FILENAME:" def_start ":" len > "/dev/stderr"
                    }
                }
                in_def = 0
            }
        }
        in_def && /^[^ \t]/ && NR > def_start + 50 {
            len = NR - def_start
            print "FUNCTION_TOO_LONG: FILENAME:" def_start ":" len > "/dev/stderr"
        }
        ' "$file" 2>&1 | while read -r line; do
            ERROR "$line"
            VIOLATIONS+=("FUNCTION_TOO_LONG: $file")
            BLOCKED=1
        done
    fi
}

# ─── 3. Cyclomatic complexity check (for/if chains) ───────────────────────────
check_cyclomatic_complexity() {
    local file="$1"

    if [ ! -f "$file" ]; then
        return 0
    fi

    # Only check source files
    case "$file" in
        *.go|*.py|*.js|*.ts) ;;
        *) return 0 ;;
    esac

    # Simple heuristic: count if/for/while per function
    # More than 10 decision points suggests high complexity

    local decision_count=0
    local content
    content=$(cat "$file" 2>/dev/null)

    # Count decision keywords (rough cyclomatic complexity estimate)
    decision_count=$(grep -cE '\b(if|elif|else if|for|while|case|&&|\|\|)\b' <<< "$content" 2>/dev/null || echo 0)

    # Normalize: if file has more than 10 decision points per 50 lines, flag it
    local line_count
    line_count=$(wc -l < "$file" 2>/dev/null || echo 1)
    local threshold=$((10 + (line_count / 50) * 3))  # Allow more in larger files

    if [ "$decision_count" -gt "$threshold" ]; then
        local ratio
        ratio=$(echo "scale=1; $decision_count * 100 / $line_count" | bc 2>/dev/null || echo "high")
        ERROR "HIGH_COMPLEXITY: $file has $decision_count decision points (ratio: ${ratio}%)"
        VIOLATIONS+=("HIGH_COMPLEXITY: $file:$decision_count")
        BLOCKED=1
    fi
}

# ─── Run all checks ────────────────────────────────────────────────────────────
INFO "Running complexity gate on files being pushed..."
echo "$CHANGED_FILES" | while read -r file; do
    [ -z "$file" ] && continue
    [ ! -f "$file" ] && continue

    check_file_length "$file" || true
    check_function_length "$file" || true
    check_cyclomatic_complexity "$file" || true
done

if [ "$BLOCKED" -eq 1 ]; then
    ERROR "Complexity gate blocked push. Fix violations above."
    echo ""
    WARN "Tip: Break large functions (>50 lines) into smaller helpers."
    WARN "Tip: Extract files >500 lines into separate modules."
    WARN "Tip: Reduce cyclomatic complexity with early returns or guard clauses."
    exit 1
fi

INFO "Complexity gate passed"
exit 0
