#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# Dark Factory Clean Branch Pre-push Hook
#
# Warns (but does NOT block) on:
#   - Uncommitted changes in working tree
#   - Uppercase in branch name (should be lowercase/kebab)
#   - Non-conventional commit messages
#
# Usage: Add to .githooks/pre-push
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
cd "$REPO_ROOT"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
ERROR() { echo -e "${RED}[clean-branch]${NC} $*"; }
WARN() { echo -e "${YELLOW}[clean-branch]${NC} $*"; }
INFO() { echo -e "${GREEN}[clean-branch]${NC} $*"; }

show_help() {
    cat << 'EOF'
Dark Factory Clean Branch Pre-push Hook (Advisory)

Warns (but does NOT block) on:
  - Uncommitted changes in working tree
  - Uppercase in branch name (should be lowercase/kebab)
  - Non-conventional commit messages on the branch

This is advisory only — it will warn but never block your push.

Exit codes:
  0 - All checks passed or warnings only
  1 - Never (this hook is advisory only)
EOF
}

for arg in "$@"; do
    case "$arg" in
        -h|--help) show_help; exit 0 ;;
    esac
fi

WARNINGS=0

# ─── 1. Uncommitted changes check ─────────────────────────────────────────────
check_uncommitted() {
    if ! command -v git &>/dev/null; then
        return 0
    fi

    if ! git rev-parse --git-dir &>/dev/null 2>&1; then
        return 0
    fi

    # Check for uncommitted changes (not staged)
    if [ -n "$(git status --porcelain 2>/dev/null)" ]; then
        WARN "UNCOMMITTED: You have uncommitted changes in your working tree"
        git status --short 2>/dev/null | head -10
        echo ""
        WARN "Consider committing before pushing: git add -A && git commit -m '...'"
        WARNINGS=$((WARNINGS + 1))
    fi

    # Check for stashed changes
    local stash_count
    stash_count=$(git stash list 2>/dev/null | wc -l || echo 0)
    if [ "$stash_count" -gt 0 ]; then
        WARN "STASHED: You have $stash_count stash(es) saved"
        git stash list 2>/dev/null | head -5
        echo ""
        WARN "Consider: git stash branch to recover or git stash drop to remove"
        WARNINGS=$((WARNINGS + 1))
    fi
}

# ─── 2. Branch name check ─────────────────────────────────────────────────────
check_branch_name() {
    if ! command -v git &>/dev/null; then
        return 0
    fi

    if ! git rev-parse --git-dir &>/dev/null 2>&1; then
        return 0
    fi

    local branch
    branch=$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD 2>/dev/null)

    if [ -z "$branch" ]; then
        return 0
    fi

    # Check for uppercase letters
    if echo "$branch" | grep -qE '[A-Z]'; then
        WARN "BRANCH_NAME: Branch '$branch' contains uppercase letters"
        WARN "Convention: Use lowercase and kebab-case (e.g., 'feature/my-branch' not 'feature/MyBranch')"
        WARNINGS=$((WARNINGS + 1))
    fi

    # Check for spaces or special characters
    if echo "$branch" | grep -qE '[[:space:]]'; then
        WARN "BRANCH_NAME: Branch '$branch' contains whitespace"
        WARNINGS=$((WARNINGS + 1))
    fi

    # Warn on very long branch names
    if [ ${#branch} -gt 50 ]; then
        WARN "BRANCH_NAME: Branch '$branch' is very long (${#branch} chars)"
        WARNINGS=$((WARNINGS + 1))
    fi
}

# ─── 3. Commit message format check ──────────────────────────────────────────
check_commit_messages() {
    if ! command -v git &>/dev/null; then
        return 0
    fi

    if ! git rev-parse --git-dir &>/dev/null 2>&1; then
        return 0
    fi

    local remote_ref="${1:-}"
    local local_ref="${2:-}"
    local local_commit="${3:-}"

    if [ -z "$remote_ref" ] || [ -z "$local_ref" ] || [ -z "$local_commit" ]; then
        return 0
    fi

    # Get the commits we're about to push
    local commits_to_check
    commits_to_check=$(git log --format=%H "$remote_ref".."$local_ref" 2>/dev/null || echo "")

    if [ -z "$commits_to_check" ]; then
        return 0
    fi

    # Conventional commits pattern: type(scope): description
    # Types: feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert
    local cc_pattern='^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\([a-z0-9/-]+\))?!?: [a-z].+'

    local bad_commits=0
    while IFS= read -r commit_hash; do
        [ -z "$commit_hash" ] && continue

        local msg
        msg=$(git log -1 --format=%B "$commit_hash" 2>/dev/null | head -1 || echo "")

        if [ -z "$msg" ]; then
            continue
        fi

        if ! grep -qE "$cc_pattern" <<< "$msg"; then
            WARN "COMMIT_MSG: $commit_hash: '$msg' does not match conventional commits format"
            WARN "  Expected: type(scope): description (e.g., feat(api): add new endpoint)"
            WARN "  Types: feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert"
            bad_commits=$((bad_commits + 1))
        fi
    done <<< "$commits_to_check"

    if [ "$bad_commits" -gt 0 ]; then
        WARN "Found $bad_commits commit(s) with non-conventional messages"
        WARNINGS=$((WARNINGS + 1))
    fi
}

# ─── Run all checks ────────────────────────────────────────────────────────────
INFO "Running clean branch advisory checks..."
echo ""

check_uncommitted
check_branch_name
check_commit_messages "$@"

echo ""

if [ "$WARNINGS" -gt 0 ]; then
    WARN "Clean branch advisory: $WARNINGS warning(s) found"
    WARN "These are advisory only — push will proceed."
else
    INFO "Clean branch checks passed"
fi

exit 0
