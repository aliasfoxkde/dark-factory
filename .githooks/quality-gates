#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# Dark Factory Quality Gates Pre-commit Hook
# Based on: backend/src/enforcement/quality_gates.py
#
# Blocks commits with:
#   - Hardcoded secrets (API keys, tokens, passwords, private keys)
#   - Console logging in production code (console.log, console.error, etc.)
#   - Fake/placeholder data (placeholder_, fake_, example.com)
#   - Placeholder code (TODO/FIXME/HACK without issue refs)
#
# Usage: Add to .githooks/pre-commit before the test/coverage section
# ─────────────────────────────────────────────────────────────────────────────
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
ERROR() { echo -e "${RED}[quality-gate]${NC} $*"; }
WARN() { echo -e "${YELLOW}[quality-gate]${NC} $*"; }
INFO() { echo -e "${GREEN}[quality-gate]${NC} $*"; }

BLOCKED=0
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# ─── 1. Secrets Detection ────────────────────────────────────────────────────
secrets_check() {
    local file="$1"
    local secrets_found=0

    # Skip test files and fixtures
    case "$file" in
        *_test.go|test_*.go|tests/|testdata/|fixtures/) return 0 ;;
    esac

    # Patterns for hardcoded secrets
    local secret_patterns=(
        # API keys
        'ghp_[0-9a-zA-Z]{36}'
        'gho_[0-9a-zA-Z]{36}'
        'glpat-[0-9a-zA-Z\-]{20,}'
        'AKIA[0-9A-Z]{16}'
        'xox[baprs]-[0-9a-zA-Z]{10,}'
        'sk-[0-9a-zA-Z]{48}'
        'sk_live_[0-9a-zA-Z]{24,}'
        'sq0[a-z]{3}-[0-9a-zA-Z]{22}'
        'sq0csp-[0-9a-zA-Z]{43}'
        # Bearer tokens
        'Bearer\s+[A-Za-z0-9_\-\.]+'
        # Private keys
        '-----BEGIN\s+(?:RSA|DSA|EC|OPENSSH)?\s*PRIVATE\s+KEY-----'
        # Generic secrets
        'api[_-]?key["\x27]\s*[:=]\s*["\x27][^"\x27]{8,}["\x27]'
        'secret["\x27]\s*[:=]\s*["\x27][^"\x27]{8,}["\x27]'
        'token["\x27]\s*[:=]\s*["\x27][^"\x27]{8,}["\x27]'
        # DB connection strings with credentials
        '(mysql|postgres|mongodb)://[^:]+:[^@]+@'
    )

    local content
    content=$(git show ":0:$file" 2>/dev/null || cat "$file" 2>/dev/null)
    [ -z "$content" ] && return 0

    for pattern in "${secret_patterns[@]}"; do
        if grep -rqE "$pattern" <<< "$content" 2>/dev/null; then
            local matches
            matches=$(grep -rnE "$pattern" <<< "$content" | head -3 || true)
            ERROR "SECRETS: $file: hardcoded secret pattern detected"
            echo "$matches" | head -3 >&2
            secrets_found=1
            BLOCKED=1
        fi
    done

    return $secrets_found
}

# ─── 2. Console Logging Detection ─────────────────────────────────────────────
console_check() {
    local file="$1"
    local found=0

    # Only check source files
    case "$file" in
        *.go|*.py|*.js|*.ts|*.jsx|*.tsx) ;;
        *) return 0 ;;
    esac

    # Skip test files
    case "$file" in
        *_test.go|test_*.go|tests/|*_test.py|*_tests.py) return 0 ;;
    esac

    local content
    content=$(git show ":0:$file" 2>/dev/null || cat "$file" 2>/dev/null)
    [ -z "$content" ] && return 0

    # Console patterns
    local console_patterns=(
        'console\.(log|error|warn|debug|info)\s*\('
        'print\s*\('
        'puts\s+'
        'System\.out\.print'
        'fmt\.Print'
        'logger\.Info\(.*\{'  # structured logger is OK
    )

    for pattern in "${console_patterns[@]}"; do
        local matches
        matches=$(grep -rnE "$pattern" <<< "$content" 2>/dev/null || true)
        if [ -n "$matches" ]; then
            # Filter out structured logging (contains { or :=)
            local suspect
            suspect=$(echo "$matches" | grep -vE '(logger\.(Info|Debug|Warn|Error)|slog\.|structlog|log\.Info|log\.Debug)' | head -5 || true)
            if [ -n "$suspect" ]; then
                ERROR "CONSOLE: $file: bare console logging detected"
                echo "$suspect" | head -5 >&2
                found=1
                BLOCKED=1
            fi
        fi
    done

    return $found
}

# ─── 3. Fake/Placeholder Data Detection ──────────────────────────────────────
fake_data_check() {
    local file="$1"
    local found=0

    case "$file" in
        *_test.py|test_*.py|tests/|testdata/|fixtures/) return 0 ;;
    esac

    local content
    content=$(git show ":0:$file" 2>/dev/null || cat "$file" 2>/dev/null)
    [ -z "$content" ] && return 0

    local fake_patterns=(
        'placeholder[_\s]'
        'fake[_\s](email|data|name|address|token)'
        'mock[_\s](email|data|name)'
        '@example\.com'
        'john\s+doe'
        '123\s+Fake\s+'
        'your_[a-z_]+'
        '<[A-Z_]+>'
        'EXAMPLE'
    )

    for pattern in "${fake_patterns[@]}"; do
        if grep -rqE "$pattern" <<< "$content" 2>/dev/null; then
            local matches
            matches=$(grep -rnE "$pattern" <<< "$content" | head -3 || true)
            WARN "FAKE_DATA: $file: placeholder/fake data detected"
            echo "$matches" | head -3 >&2
            found=1
        fi
    done

    return $found
}

# ─── 4. Placeholder Code Detection ───────────────────────────────────────────
placeholder_check() {
    local file="$1"
    local found=0

    local content
    content=$(git show ":0:$file" 2>/dev/null || cat "$file" 2>/dev/null)
    [ -z "$content" ] && return 0

    local placeholder_patterns=(
        'TODO\s*(?!.*#[0-9])'
        'FIXME\s*(?!.*#[0-9])'
        'XXX\s*(?!.*#[0-9])'
        'HACK\s*(?!.*#[0-9])'
        'raise\s+NotImplementedError\s*\('
        'pass\s*#.*TODO'
    )

    for pattern in "${placeholder_patterns[@]}"; do
        if grep -rqE "$pattern" <<< "$content" 2>/dev/null; then
            local matches
            matches=$(grep -rnE "$pattern" <<< "$content" | head -5 || true)
            WARN "PLACEHOLDER: $file: placeholder code detected (TODO/FIXME without issue ref)"
            echo "$matches" | head -5 >&2
            found=1
        fi
    done

    return $found
}

# ─── Run all checks ──────────────────────────────────────────────────────────
if [ -z "$STAGED_FILES" ]; then
    INFO "No files staged — skipping quality gates"
    exit 0
fi

INFO "Running quality gates on staged files..."
for file in $STAGED_FILES; do
    [ ! -f "$file" ] && continue

    secrets_check "$file" || true
    console_check "$file" || true
    fake_data_check "$file" || true
    placeholder_check "$file" || true
done

if [ "$BLOCKED" -eq 1 ]; then
    ERROR "Quality gates blocked commit. Fix issues above or use --no-verify to skip."
    exit 1
fi

INFO "Quality gates passed"
exit 0
